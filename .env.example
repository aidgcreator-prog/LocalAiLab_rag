# Model provider API keys (required for remote models)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# LangSmith API key (required for deployment and remote sandbox)
# LANGSMITH_API_KEY=

# Tavily API key (required for web search in researcher agent)
# TAVILY_API_KEY=
# WEBSEARCH_FETCH_FULL_CONTENT=false

# Model selection (overrides deepagents.toml)
# DEEPAGENT_LLM_PROVIDER=ollama
# DEEPAGENT_MODEL=ollama:gemma4:e4b
# WEBSEARCH_MODEL=ollama:gemma4:e4b
# WRITER_MODEL=ollama:gemma4:e4b
# CODER_MODEL=ollama:gemma4:e4b
# PLANNER_MODEL=ollama:gemma4:e4b
# REVIEWER_MODEL=ollama:gemma4:e4b
# PRESENTER_MODEL=ollama:gemma4:e4b
# DATA_SCIENTIST_MODEL=ollama:gemma4:26b
# RAG_SUB_MODEL=ollama:gemma4:26b

# Provider swap examples:
# 1) Ollama
# DEEPAGENT_LLM_PROVIDER=ollama
# DEEPAGENT_MODEL=ollama:gemma4:26b

# 2) llama.cpp (local GGUF)
# DEEPAGENT_LLM_PROVIDER=llama_cpp
# DEEPAGENT_MODEL=llama_cpp:G:/models/llama-3.1-8b-instruct.Q4_K_M.gguf
# LLAMA_CPP_MODEL_PATH=G:/models/llama-3.1-8b-instruct.Q4_K_M.gguf
# LLAMA_CPP_N_CTX=65536          # context window tokens (65536 recommended; system prompt can exceed 40k tokens)
# LLAMA_CPP_N_BATCH=512
# LLAMA_CPP_MAX_TOKENS=2048
# LLAMA_CPP_N_GPU_LAYERS=-1      # -1 = offload all layers to GPU, 0 = CPU only

# 3) Hugging Face Inference
# DEEPAGENT_LLM_PROVIDER=huggingface
# DEEPAGENT_MODEL=huggingface:meta-llama/Meta-Llama-3.1-8B-Instruct
# HUGGINGFACE_MODELS=meta-llama/Meta-Llama-3.1-8B-Instruct,mistralai/Mistral-7B-Instruct-v0.3,Qwen/Qwen2.5-7B-Instruct
# HUGGINGFACEHUB_API_TOKEN=hf_xxx
# HUGGINGFACE_TASK=text-generation
# HUGGINGFACE_MAX_NEW_TOKENS=1024

# Ollama configuration (if using local Ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Optional voice input transcription for Streamlit main chat
# VOICE_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Optional transcription model for local audio/video RAG ingest
# RAG_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Local fallback transcription model when OPENAI_API_KEY is not set
# RAG_LOCAL_TRANSCRIBE_MODEL=small
# RAG_LOCAL_TRANSCRIBE_DEVICE=cpu
# RAG_LOCAL_TRANSCRIBE_COMPUTE_TYPE=int8

# Optional Coqui TTS model for agent speech playback
# COQUI_TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# Optional Tesseract OCR binary path for multimodal RAG image OCR on Windows
# Install Tesseract first, then either set this path or add the install folder to PATH.
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
# Optional Tesseract data directory when language packs live outside the install folder
# TESSDATA_PREFIX=G:\\da\\tessdata
# Optional OCR languages passed to Tesseract (examples: eng, khm+eng)
# RAG_OCR_LANGS=eng
# Optional llama-server vision model for multimodal RAG image captioning
# RAG_VISION_MODEL=llama_server:Qwen3-VL-8B-Instruct

# RAG configuration and tuning
# RAG_EMBED_MODEL=llama_cpp:G:/llama_cpp/models/qwen3-embedding.gguf
# RAG_LLAMA_CPP_N_CTX=8192
# RAG_LLAMA_CPP_N_BATCH=256
# RAG_LLAMA_CPP_N_GPU_LAYERS=-1
# RAG_LLAMA_CPP_FLASH_ATTN=true
# RAG_OLLAMA_BASE_URL=http://localhost:11434
# RAG_OLLAMA_EMBED_URL=http://localhost:11434/api/embeddings  # legacy fallback only
# RAG_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RAG_MIN_RERANK_SCORE=0.0
# RAG_MMR_LAMBDA=0.5
# RAG_MAX_CONTEXT_TOKENS=6000
# RAG_ENABLE_VIDEO_FRAMES=true
# RAG_VIDEO_FRAME_INTERVAL_SECONDS=10
# RAG_VIDEO_MAX_FRAMES=12

# Optional evaluation judge model for evals/run_eval.py
# EVAL_JUDGE_MODEL=

YOUTUBE_API_KEY=636213812090-2utp5kgma3a3jp8a0vv8fd9f3sgcfm6k.apps.googleusercontent.com
